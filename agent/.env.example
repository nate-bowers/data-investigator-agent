# Anthropic API key — REQUIRED. Never commit the real key.
ANTHROPIC_API_KEY=sk-ant-...

# Model. Live default = Sonnet (fast/cheap).
# Set MODEL=claude-opus-4-8 for dev.
MODEL=claude-sonnet-4-6

# Loop caps (bound the agent's total work)
MAX_STEPS=15
MAX_RETRIES_PER_STEP=3
TOKEN_BUDGET=200000

# Sandbox limits
SANDBOX_TIMEOUT_S=10
SANDBOX_CPU_S=8
SANDBOX_MEM_MB=512

# CORS — comma-separated allow-list. Add your Vercel prod URL in production.
ALLOWED_ORIGINS=http://localhost:3000
